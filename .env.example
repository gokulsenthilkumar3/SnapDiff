# ─────────────────────────────────────────────────────────────────
#  SnapDiff — Environment Variables
#  Copy this file to .env.local (dashboard) and .env (worker)
# ─────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis (BullMQ) ───────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>:6380
REDIS_URL=redis://localhost:6379

# ── GitHub App ───────────────────────────────────────────────────
# Register at: https://github.com/settings/apps
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── Vercel Webhook ───────────────────────────────────────────────
# Set this as the webhook secret when registering the webhook in Vercel
VERCEL_WEBHOOK_SECRET=your-vercel-webhook-secret

# ── Worker ───────────────────────────────────────────────────────
# Port the worker Express server listens on
WORKER_PORT=3001

# ── Dashboard (Next.js) ──────────────────────────────────────────
# Full public URL of the dashboard (used for OAuth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
